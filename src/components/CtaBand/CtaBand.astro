---
import { contact, whatsappLink } from '@data/site';

interface Props {
  title?: string;
  text?: string;
}

const {
  title = 'Need heavy lifting on your UAE project?',
  text = 'Talk to our team for fast availability, transparent pricing and certified operators — 24/7.',
} = Astro.props;
---

<section class="cta-band">
  <div class="container-content cta-band__inner">
    <div>
      <h2 class="cta-band__title">{title}</h2>
      <p class="cta-band__text">{text}</p>
    </div>
    <div class="cta-band__actions">
      <a href={`tel:${contact.phoneE164}`} class="btn btn--primary">📞 Call Now</a>
      <a
        href={whatsappLink()}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--secondary cta-band__wa">💬 WhatsApp</a
      >
    </div>
  </div>
</section>

<style>
  .cta-band {
    /* Fixed dark band in both themes — the title/text are always white, so it must
       not follow --accent-secondary (which flips to near-white in dark mode). */
    background: #1a1a1a;
    border-block-start: 3px solid var(--accent-primary);
  }

  :global([data-theme='dark']) .cta-band {
    background: var(--bg-elevated);
  }

  .cta-band__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    padding-block: var(--space-16);
  }

  .cta-band__title {
    color: #fff;
    font-size: var(--text-3xl);
    max-inline-size: 22ch;
  }

  .cta-band__text {
    margin-block-start: var(--space-3);
    color: rgba(255, 255, 255, 0.7);
    max-inline-size: 48ch;
  }

  .cta-band__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .cta-band__wa {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .cta-band__wa:hover {
    background: rgba(255, 255, 255, 0.12);
  }
</style>
