---
import { contact, whatsappLink } from '@data/site';
---

<div class="mobile-cta" aria-label="Quick contact actions">
  <a href={`tel:${contact.phoneE164}`} class="mobile-cta__btn mobile-cta__btn--call">
    <span aria-hidden="true">📞</span> Call Now
  </a>
  <a
    href={whatsappLink()}
    target="_blank"
    rel="noopener noreferrer"
    class="mobile-cta__btn mobile-cta__btn--wa"
  >
    <span aria-hidden="true">💬</span> WhatsApp
  </a>
</div>

<style>
  .mobile-cta {
    position: fixed;
    inset-block-end: 0;
    inset-inline: 0;
    z-index: 95;
    display: none;
    gap: 1px;
    background: var(--border-default);
    box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.15);
  }

  .mobile-cta__btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    block-size: 64px;
    font-family: var(--font-display);
    font-weight: 700;
  }

  .mobile-cta__btn--call {
    background: var(--accent-primary);
    color: var(--text-on-accent);
  }

  .mobile-cta__btn--wa {
    background: #075e54;
    color: #fff;
  }

  @media (max-width: 48rem) {
    .mobile-cta {
      display: flex;
    }
  }
</style>
