---
import { navLinks, contact, social, emirates, site, whatsappLink } from '@data/site';
import Logo from '@components/Logo/Logo.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-content site-footer__grid">
    <div class="site-footer__brand">
      <a href="/" class="site-footer__brand-link" aria-label={`${site.name} — home`}>
        <Logo class="site-footer__logo" />
        <span>
          <strong>Lail O Nahar</strong>
          <span lang="ar" dir="rtl">ليل و نهار</span>
        </span>
      </a>
      <p class="site-footer__tagline">
        Cranes &amp; aerial work platform rentals across the UAE. Available 24/7 for construction,
        industrial and oil &amp; gas projects.
      </p>
      <a href={whatsappLink()} target="_blank" rel="noopener noreferrer" class="btn btn--primary">
        Available 24/7 — WhatsApp Now
      </a>
    </div>

    <nav class="site-footer__col" aria-label="Footer">
      <h2 class="site-footer__heading">Explore</h2>
      <ul>
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
        <li><a href="/fleet/cranes">Cranes</a></li>
        <li><a href="/fleet/man-cranes">Man-Cranes</a></li>
      </ul>
    </nav>

    <div class="site-footer__col">
      <h2 class="site-footer__heading">Areas Served</h2>
      <ul>
        {emirates.map((e) => <li>{e}</li>)}
      </ul>
    </div>

    <div class="site-footer__col">
      <h2 class="site-footer__heading">Contact</h2>
      <ul>
        {
          contact.phoneNumbers.map((phone) => (
            <li>
              <a href={`tel:${phone.e164}`}>{phone.display}</a>
            </li>
          ))
        }
        <li><a href={`mailto:${contact.email}`}>{contact.email}</a></li>
        <li>{contact.addressLine}</li>
        <li>{contact.hours}</li>
      </ul>
      <div class="site-footer__social">
        <a href={social.whatsapp} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp"
          >WhatsApp</a
        >
        <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
          >Instagram</a
        >
        <a href={social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
          >LinkedIn</a
        >
      </div>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container-content site-footer__bottom-inner">
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <p>
        Built for the UAE — Dubai • Sharjah • Ajman • Abu Dhabi • Al Ain • Fujairah • Ras Al Khaimah
        • Umm Al Quwain
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-surface);
    border-block-start: 1px solid var(--border-default);
    color: var(--text-secondary);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: var(--space-12);
    padding-block: var(--space-20) var(--space-12);
  }

  .site-footer__brand-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-primary);
  }

  .site-footer__brand-link span {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .site-footer__brand-link span span {
    color: var(--accent-primary-hover);
    font-size: var(--text-sm);
  }

  .site-footer__logo {
    inline-size: 40px;
    block-size: 40px;
  }

  .site-footer__tagline {
    margin-block: var(--space-4) var(--space-6);
    max-inline-size: 36ch;
  }

  .site-footer__heading {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-primary);
    margin-block-end: var(--space-4);
  }

  .site-footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .site-footer__col a:hover {
    color: var(--accent-primary-hover);
  }

  .site-footer__social {
    display: flex;
    gap: var(--space-4);
    margin-block-start: var(--space-6);
    font-weight: 600;
  }

  .site-footer__social a:hover {
    color: var(--accent-primary-hover);
  }

  .site-footer__bottom {
    border-block-start: 1px solid var(--border-default);
  }

  .site-footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: var(--space-6);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  @media (max-width: 64rem) {
    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 40rem) {
    .site-footer__grid {
      grid-template-columns: 1fr;
    }
    .site-footer__bottom-inner {
      padding-block-end: calc(64px + var(--space-6));
    }
  }
</style>
