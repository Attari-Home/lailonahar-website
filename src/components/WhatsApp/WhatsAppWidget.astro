---
import { whatsappLink } from '@data/site';
const href = whatsappLink();
---

<a
  class="whatsapp-widget"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chat with us on WhatsApp"
  data-wa-widget
>
  <span class="whatsapp-widget__tooltip">Chat with us on WhatsApp for a quick quote!</span>
  <span class="whatsapp-widget__pulse" aria-hidden="true"></span>
  <svg
    class="whatsapp-widget__icon"
    viewBox="0 0 32 32"
    width="30"
    height="30"
    fill="currentColor"
    aria-hidden="true"
  >
    <path
      d="M16.001 3.2c-7.07 0-12.8 5.73-12.8 12.8 0 2.26.6 4.46 1.73 6.4L3.2 28.8l6.57-1.72a12.74 12.74 0 0 0 6.23 1.6h.01c7.06 0 12.8-5.73 12.8-12.8 0-3.42-1.33-6.63-3.75-9.05A12.7 12.7 0 0 0 16 3.2zm0 23.04h-.01a10.6 10.6 0 0 1-5.4-1.48l-.39-.23-4.02 1.05 1.07-3.92-.25-.4a10.57 10.57 0 0 1-1.62-5.66c0-5.87 4.78-10.65 10.66-10.65a10.6 10.6 0 0 1 7.53 3.12 10.55 10.55 0 0 1 3.12 7.54c0 5.88-4.78 10.65-10.66 10.65zm5.85-7.98c-.32-.16-1.9-.94-2.2-1.04-.29-.11-.5-.16-.72.16-.21.32-.82 1.03-1 1.25-.19.21-.37.24-.69.08-.32-.16-1.35-.5-2.57-1.59-.95-.85-1.6-1.9-1.78-2.22-.19-.32-.02-.5.14-.66.14-.14.32-.37.48-.56.16-.19.21-.32.32-.53.11-.21.05-.4-.03-.56-.08-.16-.72-1.74-.99-2.38-.26-.62-.52-.54-.72-.55l-.61-.01c-.21 0-.56.08-.85.4-.29.32-1.11 1.09-1.11 2.66 0 1.57 1.14 3.08 1.3 3.3.16.21 2.25 3.43 5.45 4.81.76.33 1.36.53 1.82.68.76.24 1.46.21 2.01.13.61-.09 1.9-.78 2.17-1.53.27-.75.27-1.39.19-1.53-.08-.13-.29-.21-.61-.37z"
    ></path>
  </svg>
</a>

<style>
  .whatsapp-widget {
    position: fixed;
    inset-block-end: var(--space-6);
    inset-inline-end: var(--space-6);
    z-index: 90;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 56px;
    block-size: 56px;
    border-radius: var(--radius-full);
    background: #25d366;
    color: #fff;
    box-shadow: var(--shadow-lg);
    transition: transform var(--transition-spring);
  }

  .whatsapp-widget:hover {
    transform: scale(1.08);
  }

  .whatsapp-widget__pulse {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-full);
    background: #25d366;
    z-index: -1;
    animation: wa-pulse 3s infinite ease-out;
  }

  @keyframes wa-pulse {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    70%,
    100% {
      transform: scale(1.8);
      opacity: 0;
    }
  }

  .whatsapp-widget__tooltip {
    position: absolute;
    inset-inline-end: calc(100% + var(--space-3));
    inset-block-start: 50%;
    transform: translateY(-50%) translateX(8px);
    inline-size: max-content;
    max-inline-size: 220px;
    padding: var(--space-2) var(--space-3);
    background: var(--bg-surface);
    color: var(--text-primary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    font-size: var(--text-sm);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity var(--transition-fast),
      transform var(--transition-fast);
  }

  .whatsapp-widget:hover .whatsapp-widget__tooltip,
  .whatsapp-widget:focus-visible .whatsapp-widget__tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateY(-50%) translateX(0);
  }

  /* Lift above the mobile sticky CTA bar on small screens. */
  @media (max-width: 48rem) {
    .whatsapp-widget {
      inset-block-end: calc(64px + var(--space-4));
    }
    .whatsapp-widget__tooltip {
      display: none;
    }
  }
</style>
