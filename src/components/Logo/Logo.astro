  viewBox="0 0 64 64"
  role="img"
  width="63px"
  height="63px"
  aria-label="Lail O Nahar logo"
  xmlns="http://www.w3.org/2000/svg"
>
  <rect width="64" height="64" rx="12" fill="currentColor" opacity="0.0"></rect>
  <path d="M14 44 L26 16 L30 16 L30 44 Z" fill="var(--accent-primary)"></path>
  <rect x="30" y="40" width="22" height="4" fill="var(--accent-primary)"></rect>
  <rect x="46" y="20" width="3" height="24" fill="var(--accent-primary)"></rect>
  <path d="M30 22 L49 22" stroke="var(--accent-primary)" stroke-width="3"></path>
  <rect x="36" y="22" width="3" height="8" fill="#F0F0F0"></rect>
</svg>
