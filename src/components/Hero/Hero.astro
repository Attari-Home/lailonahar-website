---
import { Image } from 'astro:assets';
import { contact, emirates } from '@data/site';
import type { HeroSlide } from '@lib/media';

interface Props {
  slides: HeroSlide[];
  eyebrow?: string;
  title: string;
  subtitle?: string;
}

const { slides, eyebrow = 'Heavy Lifting, Done Right', title, subtitle } = Astro.props;

const hasSlideshow = slides.length > 1;
---

<section class="hero" data-hero>
  <div class="hero__media">
    <div class="hero__slides">
      {
        slides.map((slide, i) => (
          <div class:list={['hero__slide', { 'is-active': i === 0 }]} data-slide>
            {slide.type === 'image' ? (
              <Image
                src={slide.image}
                alt={slide.alt}
                widths={[768, 1280, 1920]}
                sizes="100vw"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'auto'}
                class="hero__image"
              />
            ) : (
              <video
                class="hero__video"
                muted
                playsinline
                preload={i === 0 ? 'auto' : 'none'}
                data-video
              >
                <source src={slide.src} type="video/mp4" />
              </video>
            )}
          </div>
        ))
      }
    </div>
    <div class="hero__overlay"></div>
  </div>

  <div class="container-content hero__content">
    <div class="hero__panel">
      <div class="hero__badge-row">
        <span class="eyebrow hero__eyebrow">{eyebrow}</span>
        <span class="badge hero__badge">24/7 Service</span>
      </div>
      <h1 class="hero__title">{title}</h1>
      {subtitle && <p class="hero__subtitle">{subtitle}</p>}

      <div class="hero__actions">
        <a href="/contact" class="btn btn--primary">Get a Free Quote</a>
        <a href="/fleet" class="btn btn--ghost-inverse">View Our Fleet</a>
      </div>

      <p class="hero__locations">
        Serving {emirates.join(' • ')}
      </p>
    </div>

    <a href={`tel:${contact.phoneE164}`} class="hero__phone">
      📞 {contact.phoneDisplay}
    </a>
  </div>

  {
    hasSlideshow && (
      <div class="hero__dots" data-hero-dots role="tablist" aria-label="Hero slides">
        {slides.map((_, i) => (
          <button
            type="button"
            class:list={['hero__dot', { 'is-active': i === 0 }]}
            data-dot
            data-index={i}
            aria-label={`Show slide ${i + 1}`}
          />
        ))}
      </div>
    )
  }

  <a href="#trust" class="hero__scroll" aria-label="Scroll to content">
    <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M6 9l6 6 6-6"></path>
    </svg>
  </a>
</section>

<script>
  function initHero() {
    const hero = document.querySelector('[data-hero]');
    if (!hero) return;

    const slides = Array.from(hero.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(hero.querySelectorAll<HTMLButtonElement>('[data-dot]'));
    if (slides.length === 0) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const IMAGE_MS = 6000;

    // Single slide: just play the lone video on loop, nothing to cycle.
    if (slides.length === 1) {
      const onlyVideo = slides[0].querySelector('video');
      if (onlyVideo) {
        onlyVideo.loop = true;
        onlyVideo.play?.().catch(() => {});
      }
      return;
    }

    let current = 0;
    let timer: ReturnType<typeof setTimeout> | undefined;

    const clearTimer = () => {
      if (timer) {
        clearTimeout(timer);
        timer = undefined;
      }
    };
    const scheduleNext = (ms: number) => {
      clearTimer();
      timer = setTimeout(() => go(current + 1), ms);
    };
    const stopVideo = (slide: HTMLElement) => {
      const v = slide.querySelector('video');
      if (v) {
        v.pause();
        v.onended = null;
        try {
          v.currentTime = 0;
        } catch {
          /* metadata not ready — ignore */
        }
      }
    };

    function activate(slide: HTMLElement) {
      clearTimer();
      const video = slide.querySelector('video');
      if (video) {
        try {
          video.currentTime = 0;
        } catch {
          /* ignore */
        }
        video.onended = () => go(current + 1);
        if (!reduceMotion) {
          const p = video.play();
          if (p) p.catch(() => scheduleNext(IMAGE_MS));
        }
        // Safety net if the video stalls or can't autoplay.
        if (reduceMotion) scheduleNext(IMAGE_MS);
      } else if (!reduceMotion) {
        scheduleNext(IMAGE_MS);
      }
    }

    function go(next: number) {
      const target = ((next % slides.length) + slides.length) % slides.length;
      if (target === current) return;
      const prev = slides[current];
      stopVideo(prev);
      prev.classList.remove('is-active');
      dots[current]?.classList.remove('is-active');

      current = target;
      const slide = slides[current];
      slide.classList.add('is-active');
      dots[current]?.classList.add('is-active');
      activate(slide);
    }

    dots.forEach((dot) =>
      dot.addEventListener('click', () => go(Number(dot.dataset.index)))
    );

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        clearTimer();
      } else if (!slides[current].querySelector('video') && !reduceMotion) {
        scheduleNext(IMAGE_MS);
      }
    });

    activate(slides[current]);
  }

  document.addEventListener('astro:page-load', initHero);
</script>

<style>
  .hero {
    position: relative;
    min-block-size: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .hero__slides {
    position: absolute;
    inset: 0;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .hero__slide.is-active {
    opacity: 1;
  }

  .hero__image,
  .hero__video {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(0, 0, 0, 0.78) 0%,
      rgba(0, 0, 0, 0.55) 45%,
      rgba(0, 0, 0, 0.35) 100%
    );
  }

  :global([data-theme='dark']) .hero__overlay {
    background: linear-gradient(
      105deg,
      rgba(0, 0, 0, 0.88) 0%,
      rgba(0, 0, 0, 0.7) 45%,
      rgba(0, 0, 0, 0.55) 100%
    );
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding-block: var(--space-24) var(--space-16);
  }

  .hero__panel {
    max-inline-size: 720px;
  }

  .hero__badge-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-block-end: var(--space-4);
  }

  .hero__eyebrow {
    color: var(--accent-primary);
  }

  .hero__badge {
    background: var(--accent-primary);
    color: var(--text-on-accent);
    font-weight: 700;
  }

  .hero__title {
    color: #fff;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.05;
  }

  .hero__subtitle {
    margin-block-start: var(--space-6);
    color: rgba(255, 255, 255, 0.85);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    max-inline-size: 56ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-block-start: var(--space-8);
  }

  .hero__locations {
    margin-block-start: var(--space-6);
    color: rgba(255, 255, 255, 0.7);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .hero__phone {
    display: none;
  }

  .hero__dots {
    position: absolute;
    inset-block-end: var(--space-6);
    inset-inline-end: var(--space-8);
    z-index: 2;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .hero__dot {
    inline-size: 10px;
    block-size: 10px;
    padding: 0;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.6);
    background: transparent;
    cursor: pointer;
    transition:
      inline-size var(--transition-base),
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .hero__dot:hover {
    background: rgba(255, 255, 255, 0.5);
  }

  .hero__dot.is-active {
    inline-size: 26px;
    background: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .hero__scroll {
    position: absolute;
    inset-block-end: var(--space-6);
    inset-inline-start: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.8);
    animation: hero-bounce 2s infinite;
  }

  @keyframes hero-bounce {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(8px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__slide {
      transition: none;
    }
  }
</style>
</content>
</invoke>
