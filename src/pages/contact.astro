---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/PageHeader/PageHeader.astro';
import ContactForm from '@components/ContactForm/ContactForm.astro';
import { contact, whatsappLink } from '@data/site';

const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(contact.mapQuery)}&output=embed`;
---

<BaseLayout
  title="Contact Lail O Nahar — Get a Free Quote"
  description="Contact Lail O Nahar Machinery Rentals for crane and man-crane hire across the UAE. Call, WhatsApp or request a free quote online. 24/7 service in Dubai, Sharjah, Ajman & Abu Dhabi."
  hideWhatsApp={true}
>
  <PageHeader
    eyebrow="Contact"
    title="Get a free quote"
    text="Tell us about your project and our team will respond fast with availability and pricing. Prefer to talk? Call or WhatsApp us any time — we're open 24/7."
  />

  <section class="section">
    <div class="container-content contact__grid">
      <div class="contact__form">
        <ContactForm />
      </div>

      <aside class="contact__aside">
        <div class="contact__card surface-card">
          <h2>Reach us directly</h2>
          <ul class="contact__list">
            <li>
              <span class="contact__label">Phone</span>
              <a href={`tel:${contact.phoneE164}`}>{contact.phoneDisplay}</a>
            </li>
            <li>
              <span class="contact__label">WhatsApp</span>
              <a href={whatsappLink()} target="_blank" rel="noopener noreferrer"> Chat with us </a>
            </li>
            <li>
              <span class="contact__label">Email</span>
              <a href={`mailto:${contact.email}`}>{contact.email}</a>
            </li>
            <li>
              <span class="contact__label">Address</span>
              <span>{contact.addressLine}</span>
            </li>
            <li>
              <span class="contact__label">Hours</span>
              <span>{contact.hours}</span>
            </li>
          </ul>
        </div>

        <div class="contact__map">
          <iframe
            src={mapSrc}
            title="Lail O Nahar location map"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen></iframe>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .contact__card {
    padding: var(--space-8);
  }

  .contact__card h2 {
    font-size: var(--text-2xl);
    margin-block-end: var(--space-6);
  }

  .contact__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .contact__list li {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .contact__label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .contact__list a {
    color: var(--text-primary);
    font-weight: 600;
  }

  .contact__list a:hover {
    color: var(--accent-primary-hover);
  }

  .contact__map {
    margin-block-start: var(--space-6);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-default);
    aspect-ratio: 4 / 3;
  }

  .contact__map iframe {
    inline-size: 100%;
    block-size: 100%;
    border: 0;
  }

  @media (max-width: 64rem) {
    .contact__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
