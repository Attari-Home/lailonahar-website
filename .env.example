# ============================================================
# Lail O Nahar — Environment Variables (sample)
# Copy to `.env` and fill in real values. Never commit `.env`.
# ============================================================

# Public site URL (used for canonical + sitemap)
SITE_URL=https://lail-o-nahar.pages.dev

# Web3Forms access key — https://web3forms.com (used by the contact form)
PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# Cloudflare Web Analytics beacon token (optional)
PUBLIC_CF_BEACON_TOKEN=
