{
    "ci": {
        "collect": {
            "staticDistDir": "./dist",
            "url": [
                "http://localhost/index.html",
                "http://localhost/fleet/index.html",
                "http://localhost/contact/index.html"
            ],
            "numberOfRuns": 1
        },
        "assert": {
            "assertions": {
                "categories:performance": [
                    "error",
                    {
                        "minScore": 0.95
                    }
                ],
                "categories:accessibility": [
                    "error",
                    {
                        "minScore": 1.0
                    }
                ],
                "categories:seo": [
                    "error",
                    {
                        "minScore": 1.0
                    }
                ],
                "categories:best-practices": [
                    "error",
                    {
                        "minScore": 0.95
                    }
                ]
            }
        },
        "upload": {
            "target": "temporary-public-storage"
        }
    }
}